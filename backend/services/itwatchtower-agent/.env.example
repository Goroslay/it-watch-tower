# ──────────────────────────────────────────────────────────────
# IT Watch Tower Agent — variables de entorno
# Copia este archivo a /etc/itwatchtower-agent.env y ajusta los
# valores según tu entorno.  Las variables sin valor por defecto
# son REQUERIDAS para la funcionalidad correspondiente.
# ──────────────────────────────────────────────────────────────

# ── Conexión NATS ─────────────────────────────────────────────
NATS_URL=nats://localhost:4222
# NATS_USER=
# NATS_PASSWORD=

# ── Identificación del agente ─────────────────────────────────
# Por defecto usa el hostname del sistema
# AGENT_NAME=mi-servidor-01

# ── Intervalos de recolección ─────────────────────────────────
METRICS_INTERVAL=15s
LOGS_INTERVAL=30s

# ── Logs del sistema (tail de archivos genéricos) ─────────────
# Lista separada por comas de rutas absolutas
# LOG_PATHS=/var/log/syslog,/var/log/auth.log
LOG_TAIL_FROM_START=false

# ── Rutas de disco extra (uso de particiones) ─────────────────
# DISK_PATHS=/DATOS01,/DATOS02

# ── Acciones remotas ──────────────────────────────────────────
# Unidades systemd que se pueden reiniciar desde el dashboard
# ALLOWED_UNITS=nginx.service,tomcat.service,wildfly.service
# Permitir reinicio completo del servidor desde el dashboard
RESTART_SERVER_ENABLED=false

# ── Nginx ─────────────────────────────────────────────────────
# Métricas de proceso (CPU, RSS, hilos, conexiones activas)
# Formato: nombre:ruta_al_binario_o_cadena_en_cmdline
# NGINX_PATHS=main:/usr/sbin/nginx

# Logs de error → visibles en tab Logs del dashboard
# NGINX_LOG_PATHS=main:/var/log/nginx/error.log

# Access log → métricas de requests y errores (soporta glob)
# NGINX_ACCESS_LOG_PATHS=main:/var/log/nginx/access.log

# ── Tomcat ────────────────────────────────────────────────────
# Métricas: proceso + JVM heap vía jstat + conexiones activas
# Formato: nombre:ruta_base_de_la_instalación
# El agente busca el proceso java cuyo cmdline contiene esa ruta
# TOMCAT_PATHS=tomcat01:/DATOS01/tomcat/tomcat01,tomcat02:/DATOS01/tomcat/tomcat02

# Logs de catalina → visibles en tab Logs
# TOMCAT_LOG_PATHS=tomcat01:/DATOS01/tomcat/tomcat01/logs/catalina.out,tomcat02:/DATOS01/tomcat/tomcat02/logs/catalina.out

# Access log → métricas requests/errores (glob para logs rotativos)
# TOMCAT_ACCESS_LOG_PATHS=tomcat01:/DATOS01/tomcat/tomcat01/logs/localhost_access_log*.txt,tomcat02:/DATOS01/tomcat/tomcat02/logs/localhost_access_log*.txt

# ── WildFly ───────────────────────────────────────────────────
# Métricas: proceso + JVM heap vía jstat + conexiones activas
# WILDFLY_PATHS=wf01:/DATOS01/wildfly/wf01,wf02:/DATOS01/wildfly/wf02

# Logs del servidor → visibles en tab Logs
# WILDFLY_LOG_PATHS=wf01:/DATOS01/wildfly/wf01/standalone/log/server.log

# Access log → métricas requests/errores
# WILDFLY_ACCESS_LOG_PATHS=wf01:/DATOS01/wildfly/wf01/standalone/log/access.log

# ── PM2 ───────────────────────────────────────────────────────
# Métricas: estado, CPU, memoria, reinicios de todos los procesos PM2
PM2_ENABLED=false

# Logs de apps PM2 → visibles en tab Logs
# PM2_LOG_PATHS=app1:/home/deploy/.pm2/logs/app1-error.log,app2:/home/deploy/.pm2/logs/app2-error.log

# ── Oracle ────────────────────────────────────────────────────
# Requiere go-ora DSN: oracle://user:pass@host:1521/service_name
ORACLE_ENABLED=false
# ORACLE_DSN=oracle://monitor:password@localhost:1521/ORCL

# ── Variables de sistema (leídas automáticamente) ─────────────
# OS_VERSION se puede forzar si la detección automática falla
# OS_VERSION=Oracle Linux 9.4
